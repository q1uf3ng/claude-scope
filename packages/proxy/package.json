{
  "name": "@q1uf3ng/claude-scope",
  "version": "0.1.0",
  "description": "DevTools for Claude API & Claude Code — real-time proxy, cost tracking, and observability dashboard",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "claude-scope": "dist/cli.js"
  },
  "files": [
